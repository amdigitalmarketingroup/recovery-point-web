---
/**
 * Home — / (es-MX)
 *
 * Sections in order:
 *  1. Hero — Authority-led headline + dual CTA + accreditation row
 *  2. Three-pillar split (Recuperación · Vitalidad · Belleza)
 *  3. Stats counter row (springs on view)
 *  4. Why Recovery Point — 5 differentiators
 *  5. CTA block — WhatsApp primary, call secondary
 *
 * Every CTA fires a real WA deeplink or routes to a real page.
 * Sub-pages /nad /metodo /nosotros /espacio /reservar light up
 * progressively as Fases 5–7 ship; meanwhile the hero secondary CTA
 * already lands on /servicios (which exists).
 */
import BaseLayout from '@/layouts/BaseLayout.astro'
import HeroBackground from '@/components/HeroBackground.astro'
import PillarCard from '@/components/PillarCard.astro'
import { StatCounter } from '@/components/StatCounter'
import { t } from '@/i18n/messages'
import { telLink, whatsappLink } from '@/lib/contact'

const locale = 'es' as const
const wa = whatsappLink('generic')

const stats = t(locale, 'home.stats.items') as Array<{ value: number; suffix: string; label: string }>
const whyItems = t(locale, 'home.why.items') as Array<{ title: string; description: string }>
---

<BaseLayout
  title={t(locale, 'home.hero.eyebrow')}
  description={t(locale, 'home.hero.subtitle')}
>
  {/* ─────────────────────────────── HERO ─────────────────────────────── */}
  <section class="relative isolate overflow-hidden">
    <HeroBackground />
    <div class="container-rp pt-12 pb-16 sm:pt-20 sm:pb-24 lg:pt-28 lg:pb-32">
      <p class="eyebrow inline-flex items-center gap-2" data-reveal>
        <span class="inline-block w-1.5 h-1.5 rounded-full bg-mint-500 animate-pulse"></span>
        {t(locale, 'home.hero.eyebrow')}
      </p>

      <h1
        class="mt-5 text-[44px] sm:text-[64px] lg:text-[88px] font-display font-semibold leading-[1.02] tracking-tight text-balance max-w-5xl"
        data-reveal
        set:html={t(locale, 'home.hero.title')}
      />

      <p
        class="mt-6 max-w-2xl text-[17px] sm:text-[19px] lg:text-[20px] text-ink-700 leading-relaxed text-pretty"
        data-reveal
      >
        {t(locale, 'home.hero.subtitle')}
      </p>

      <div class="mt-10 flex flex-col sm:flex-row gap-3" data-reveal>
        <a
          href={wa}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2 h-14 px-7 rounded-full bg-cobalt-700 text-white text-[16px] font-semibold hover:bg-cobalt-800 hover:shadow-lg hover:shadow-cobalt-800/25 transition-all duration-[var(--duration-micro)] [transition-timing-function:var(--ease-out-quart)] active:scale-[0.98]"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M.057 24l1.687-6.163a11.867 11.867 0 01-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.817 11.817 0 018.413 3.488 11.824 11.824 0 013.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 01-5.688-1.448L.057 24z"/>
          </svg>
          {t(locale, 'home.hero.primaryCta')}
        </a>
        <a
          href="/servicios"
          class="inline-flex items-center justify-center gap-2 h-14 px-7 rounded-full bg-white text-cobalt-800 border border-cobalt-200 text-[16px] font-semibold hover:border-cobalt-400 hover:bg-cobalt-50 transition-all duration-[var(--duration-micro)] [transition-timing-function:var(--ease-out-quart)] active:scale-[0.98]"
        >
          {t(locale, 'home.hero.secondaryCta')}
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="transition-transform group-hover:translate-x-1">
            <line x1="5" y1="12" x2="19" y2="12"/>
            <polyline points="12 5 19 12 12 19"/>
          </svg>
        </a>
      </div>

      <p
        class="mt-12 text-[12px] sm:text-[13px] uppercase tracking-[0.18em] text-ink-500 font-semibold max-w-xl"
        data-reveal
      >
        {t(locale, 'home.hero.accreditation')}
      </p>
    </div>
  </section>

  {/* ─────────────────────────────── THREE PILLARS ─────────────────────────────── */}
  <section class="relative section-y">
    <div class="container-rp">
      <div class="mb-12 max-w-3xl">
        <p class="eyebrow" data-reveal>{t(locale, 'home.pillars.eyebrow')}</p>
        <h2
          class="mt-3 text-[36px] sm:text-[48px] lg:text-[56px] font-display font-semibold leading-[1.05] tracking-tight text-balance"
          data-reveal
        >
          {t(locale, 'home.pillars.title')}
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 sm:gap-5">
        <PillarCard
          accent="cobalt"
          chip={t(locale, 'home.pillars.recovery.chip')}
          title={t(locale, 'home.pillars.recovery.title')}
          description={t(locale, 'home.pillars.recovery.description')}
          intent="iv-generic"
          href="/servicios"
        />
        <PillarCard
          accent="amber"
          chip={t(locale, 'home.pillars.vitality.chip')}
          title={t(locale, 'home.pillars.vitality.title')}
          description={t(locale, 'home.pillars.vitality.description')}
          intent="nad"
        />
        <PillarCard
          accent="mint"
          chip={t(locale, 'home.pillars.beauty.chip')}
          title={t(locale, 'home.pillars.beauty.title')}
          description={t(locale, 'home.pillars.beauty.description')}
          intent="iv-generic"
          href="/servicios"
        />
      </div>
    </div>
  </section>

  {/* ─────────────────────────────── STATS ─────────────────────────────── */}
  <section class="relative section-y bg-cobalt-800 text-white overflow-hidden">
    {/* Subtle gradient overlay */}
    <div class="absolute inset-0 bg-gradient-to-br from-cobalt-800 via-cobalt-900 to-cobalt-800 -z-10"></div>
    <div class="absolute top-0 right-0 w-[400px] h-[400px] rounded-full opacity-20 blur-3xl bg-mint-500 -z-10"></div>

    <div class="container-rp">
      <div class="mb-12 max-w-3xl">
        <p class="eyebrow text-mint-300" data-reveal>{t(locale, 'home.stats.eyebrow')}</p>
        <h2
          class="mt-3 text-[36px] sm:text-[48px] lg:text-[56px] font-display font-semibold leading-[1.05] tracking-tight text-balance text-white"
          data-reveal
        >
          {t(locale, 'home.stats.title')}
        </h2>
      </div>

      <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 sm:gap-10">
        {stats.map((s, i) => (
          <StatCounter
            client:visible
            value={s.value}
            suffix={s.suffix}
            label={s.label}
            decimal={s.value === 4.9}
            className={`[--counter-delay:${i * 100}ms]`}
          />
        ))}
      </div>
    </div>

    {/* Override StatCounter colors on the dark band */}
    <style>
      section.bg-cobalt-800 [class*="text-cobalt-800"] { color: var(--color-amber-300) !important; }
      section.bg-cobalt-800 [class*="text-cobalt-600"] { color: var(--color-mint-300) !important; }
      section.bg-cobalt-800 [class*="text-ink-500"]    { color: rgba(255,255,255,0.7) !important; }
    </style>
  </section>

  {/* ─────────────────────────────── WHY RP ─────────────────────────────── */}
  <section class="relative section-y">
    <div class="container-rp grid grid-cols-1 lg:grid-cols-12 gap-12">
      <div class="lg:col-span-4 lg:sticky lg:top-28 self-start">
        <p class="eyebrow" data-reveal>{t(locale, 'home.why.eyebrow')}</p>
        <h2
          class="mt-3 text-[36px] sm:text-[48px] font-display font-semibold leading-[1.05] tracking-tight text-balance"
          data-reveal
        >
          {t(locale, 'home.why.title')}
        </h2>
      </div>

      <div class="lg:col-span-8 space-y-4">
        {whyItems.map((item, i) => (
          <div
            data-reveal
            style={`transition-delay: ${i * 80}ms`}
            class="flex items-start gap-5 p-6 sm:p-7 rounded-2xl bg-white border border-cobalt-100/60 hover:border-cobalt-300 hover:shadow-lg hover:shadow-cobalt-800/5 transition-all duration-[var(--duration-reveal)] [transition-timing-function:var(--ease-out-quart)]"
          >
            <span class="shrink-0 inline-flex items-center justify-center w-9 h-9 rounded-full bg-cobalt-50 text-cobalt-700 font-display font-semibold tabular-nums text-[16px]">
              {String(i + 1).padStart(2, '0')}
            </span>
            <div>
              <h3 class="font-display text-[20px] sm:text-[22px] font-semibold leading-tight text-ink-900">
                {item.title}
              </h3>
              <p class="mt-2 text-[15px] sm:text-[16px] text-ink-700 leading-relaxed text-pretty">
                {item.description}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* ─────────────────────────────── FINAL CTA ─────────────────────────────── */}
  <section class="relative section-y bg-gradient-to-br from-mint-50 via-ivory-50 to-cobalt-50/40">
    <div class="container-rp text-center">
      <h2
        class="text-[36px] sm:text-[48px] lg:text-[64px] font-display font-semibold leading-[1.05] tracking-tight text-balance max-w-3xl mx-auto"
        data-reveal
      >
        {t(locale, 'home.cta.title')}
      </h2>
      <p
        class="mt-5 max-w-xl mx-auto text-[16px] sm:text-[18px] text-ink-700 leading-relaxed text-pretty"
        data-reveal
      >
        {t(locale, 'home.cta.subtitle')}
      </p>
      <div class="mt-10 flex flex-col sm:flex-row gap-3 justify-center" data-reveal>
        <a
          href={wa}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2 h-14 px-8 rounded-full bg-mint-500 text-white text-[16px] font-semibold hover:bg-mint-600 hover:shadow-lg hover:shadow-mint-600/30 transition-all duration-[var(--duration-micro)] [transition-timing-function:var(--ease-out-quart)] active:scale-[0.98]"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M.057 24l1.687-6.163a11.867 11.867 0 01-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.817 11.817 0 018.413 3.488 11.824 11.824 0 013.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 01-5.688-1.448L.057 24z"/></svg>
          {t(locale, 'home.cta.primary')}
        </a>
        <a
          href={telLink}
          class="inline-flex items-center justify-center gap-2 h-14 px-8 rounded-full bg-white text-cobalt-800 border border-cobalt-200 text-[16px] font-semibold hover:border-cobalt-400 hover:bg-cobalt-50 transition-all duration-[var(--duration-micro)] [transition-timing-function:var(--ease-out-quart)] active:scale-[0.98]"
        >
          {t(locale, 'home.cta.secondary')}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
