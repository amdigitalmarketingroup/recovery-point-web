---
/**
 * /servicios — full catalog index.
 *
 * Renders the 9 service entries from src/lib/services-catalog.ts as cards
 * grouped by pillar (Recuperación / Vitalidad / Belleza). Cards link to
 * sub-pages /servicios/{slug} which will populate in Fase 4. Until those
 * sub-pages ship, the cards open a WA deeplink pre-typed for that service
 * — so every card click is real, no cascarón.
 */
import BaseLayout from '@/layouts/BaseLayout.astro'
import { t, getLocaleFromPath, localizedPath } from '@/i18n/messages'
import { SERVICES, type Pillar } from '@/lib/services-catalog'
import { whatsappLink, type WhatsAppIntent } from '@/lib/contact'

const locale = getLocaleFromPath(Astro.url.pathname)

const intentByKey: Record<string, WhatsAppIntent> = {
  iv:       'iv-generic',
  massage:  'massage-generic',
  sauna:    'sauna',
  cryo:     'cryo',
  ice:      'ice',
  redlight: 'red-light',
  boots:    'boots',
  fisio:    'fisio',
  stem:     'stem',
}

const pillarMeta: Record<Pillar, { label: string; eyebrow: string; accent: string }> = {
  recovery:  { label: t(locale, 'home.pillars.recovery.title'),  eyebrow: t(locale, 'services.filters.recovery'), accent: 'cobalt' },
  vitality:  { label: t(locale, 'home.pillars.vitality.title'),  eyebrow: t(locale, 'services.filters.vitality'), accent: 'amber'  },
  beauty:    { label: t(locale, 'home.pillars.beauty.title'),    eyebrow: t(locale, 'services.filters.beauty'),   accent: 'mint'   },
}

// Mario confirmed (2026-05-23): stem cells IS an announced service — restore
// the card to the Vitalidad pillar. The invented $500 price has been removed
// from the detail page FAQ + quickFacts; the catalog card itself doesn't
// show a price, so it's safe to display alongside bookable services.
const grouped: Record<Pillar, typeof SERVICES> = { recovery: [], vitality: [], beauty: [] }
SERVICES.forEach((s) => grouped[s.pillar].push(s))

// Glassmorphism palette — semi-transparent white tinted with the accent's
// hue. The page body has aurora orbs (added below) so the backdrop-blur has
// something to refract. The chip uses a more saturated tint so it still pops
// against the frosted surface.
const accentClasses: Record<string, { bg: string; chip: string; ring: string; tint: string }> = {
  cobalt:     { bg: 'bg-white/55',          chip: 'bg-cobalt-100/80 text-cobalt-800',     ring: 'group-hover:ring-cobalt-300/70',     tint: 'from-cobalt-100/30' },
  periwinkle: { bg: 'bg-white/55',          chip: 'bg-cobalt-100/80 text-cobalt-800',     ring: 'group-hover:ring-cobalt-300/70',     tint: 'from-cobalt-100/30' },
  mint:       { bg: 'bg-white/55',          chip: 'bg-cobalt-100/80 text-cobalt-800',     ring: 'group-hover:ring-cobalt-300/70',     tint: 'from-mint-100/40' },
  amber:      { bg: 'bg-white/55',          chip: 'bg-amber-300/80 text-cobalt-800',      ring: 'group-hover:ring-amber-300/70',      tint: 'from-amber-200/40' },
  ivory:      { bg: 'bg-white/55',          chip: 'bg-ivory-200/80 text-ink-700',         ring: 'group-hover:ring-cobalt-200/70',     tint: 'from-ivory-100/40' },
}
---

<BaseLayout title={t(locale, 'nav.services')} description={t(locale, 'services.hero.subtitle')}>
  {/* Aurora backdrop — pastel orbs so the glassmorphism cards have something
      to refract. Position fixed-but-clipped to the main area; behind content. */}
  <div aria-hidden class="pointer-events-none fixed inset-0 -z-10 overflow-hidden">
    <div class="absolute -top-32 -left-32 size-[640px] rounded-full bg-cobalt-300/30 blur-[140px]"></div>
    <div class="absolute top-1/3 -right-40 size-[560px] rounded-full bg-amber-300/25 blur-[140px]"></div>
    <div class="absolute bottom-0 left-1/3 size-[520px] rounded-full bg-periwinkle-400/25 blur-[140px]"></div>
    <div class="absolute inset-0 bg-ivory-50/40"></div>
  </div>

  <section class="container-rp section-y">
    <p class="eyebrow" data-reveal>{t(locale, 'services.hero.eyebrow')}</p>
    <h1 class="mt-4 text-[40px] sm:text-[56px] lg:text-[68px] font-display font-semibold leading-[1.05] tracking-tight text-balance max-w-4xl" data-reveal>
      {t(locale, 'services.hero.title')}
    </h1>
    <p class="mt-6 max-w-2xl text-[17px] sm:text-[18px] text-ink-700 leading-relaxed text-pretty" data-reveal>
      {t(locale, 'services.hero.subtitle')}
    </p>
  </section>

  {(['recovery', 'vitality', 'beauty'] as Pillar[]).map((pillar) => (
    grouped[pillar].length > 0 && (
      <section class="container-rp pb-16 sm:pb-24">
        <div class="flex items-baseline justify-between mb-8" data-reveal>
          <div>
            <p class="eyebrow">{pillarMeta[pillar].eyebrow}</p>
            <h2 class="mt-2 text-[32px] sm:text-[40px] font-display font-semibold leading-tight">{pillarMeta[pillar].label}</h2>
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {grouped[pillar].map((svc, index) => {
            const accent = accentClasses[svc.accent]
            const i18n = svc.i18nKey
            const intent = intentByKey[i18n]
            // If a sub-page exists for this service, route to it. Otherwise
            // open the typed WhatsApp deeplink. Single source of truth: the
            // detailPages set below. All 9 detail pages now shipped.
            const detailPages = new Set(['iv', 'masajes', 'sauna', 'cryo', 'ice', 'red-light', 'botas', 'fisio', 'stem'])
            const href = detailPages.has(svc.slug)
              ? `/servicios/${svc.slug}`
              : whatsappLink(intent)
            const isInternal = detailPages.has(svc.slug)
            return (
              <a
                href={href}
                {...(isInternal ? {} : { target: '_blank', rel: 'noopener noreferrer' })}
                data-reveal
                style={`transition-delay: ${index * 60}ms`}
                class={`group relative flex flex-col gap-4 rounded-3xl p-6 sm:p-7 ${accent.bg} backdrop-blur-2xl backdrop-saturate-150 ring-1 ring-white/45 shadow-[inset_0_1px_0_rgba(255,255,255,0.6),0_8px_30px_-12px_rgba(31,45,90,0.18)] hover:-translate-y-1 hover:shadow-[inset_0_1px_0_rgba(255,255,255,0.8),0_24px_48px_-16px_rgba(31,45,90,0.28)] transition-all duration-[var(--duration-reveal)] [transition-timing-function:var(--ease-out-quart)] ring-offset-2 ${accent.ring} hover:ring-2`}
              >
                {/* Accent gradient wash inside the glass — subtle, hue from the accent */}
                <div aria-hidden class={`pointer-events-none absolute inset-0 rounded-3xl bg-gradient-to-br ${accent.tint} via-transparent to-transparent opacity-70`}></div>
                <div class="relative">
                <div class="flex items-center justify-between">
                  <span class={`inline-flex items-center px-2.5 h-6 rounded-full text-[10px] font-sans-display font-semibold tracking-[0.18em] tabular-nums ${accent.chip}`}>
                    {String(SERVICES.indexOf(svc) + 1).padStart(2, '0')}
                  </span>
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" class="text-cobalt-700 group-hover:translate-x-1 transition-transform duration-[var(--duration-micro)]" aria-hidden="true">
                    <line x1="5" y1="12" x2="19" y2="12"/>
                    <polyline points="12 5 19 12 12 19"/>
                  </svg>
                </div>
                <div class="flex-1">
                  <h3 class="font-sans-display text-[22px] sm:text-[26px] font-semibold leading-[1.1] tracking-[-0.02em] text-cobalt-900">
                    {t(locale, `services.items.${i18n}.name`)}
                  </h3>
                  <p class="mt-3 text-[14px] sm:text-[15px] text-ink-700 leading-relaxed">
                    {t(locale, `services.items.${i18n}.tagline`)}
                  </p>
                </div>
                <div class="flex items-center justify-between pt-4 border-t border-white/40">
                  <span class="inline-flex items-center gap-1.5 text-[10px] font-semibold uppercase tracking-[0.16em] text-cobalt-700">
                    <span class="inline-block size-1 rounded-full bg-cobalt-700"></span>
                    {t(locale, `services.items.${i18n}.chip`)}
                  </span>
                  <span class="text-[11px] font-sans-display font-semibold uppercase tracking-[0.14em] text-ink-500 tabular-nums">
                    {svc.durationMin} min
                  </span>
                </div>
                </div>{/* /relative wrapper for glass content */}
              </a>
            )
          })}
        </div>

      </section>
    )
  ))}
</BaseLayout>
