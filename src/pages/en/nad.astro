---
/**
 * /nad — NAD+ dedicated landing.
 *
 * High-ticket service ($3,600–$4,800), most premium-positioned on the menu.
 * Has its own landing because it deserves a distinct narrative + FAQ + CTA
 * (vs being a row in the IV catalog). Uses editorial photography + cobalt
 * frame patterns from the Infusion reference.
 */
import BaseLayout from '@/layouts/BaseLayout.astro'
import { t, getLocaleFromPath, getLocaleFromPath } from '@/i18n/messages'
import { telLink, whatsappLink } from '@/lib/contact'
import { SUEROS } from '@/lib/services-catalog'
import { formatMxn } from '@/lib/utils'

const locale = getLocaleFromPath(Astro.url.pathname)
const wa = whatsappLink('nad')

const NAD_FAMILY = SUEROS.filter((s) => s.family === 'nad')
  .sort((a, b) => a.durationMin - b.durationMin)

const whoFor = t(locale, 'nad.whoFor.items') as string[]
const faq = t(locale, 'nad.faq.items') as Array<{ q: string; a: string }>
---

<BaseLayout
  title="NAD+ · Energía celular real"
  description={t(locale, 'nad.hero.subtitle')}
>
  {/* ───────────── HERO — dark frame, editorial ───────────── */}
  <section data-nav-theme="dark" class="relative isolate overflow-hidden bg-cobalt-900">
    <div class="absolute inset-0 -z-10">
      <picture>
        <source srcset="/img/services/nad.webp?v=12" type="image/webp" />
        <img src="/img/services/nad.webp?v=12" alt="NAD+ en Recovery Point Mexicali" class="size-full object-cover" loading="eager" fetchpriority="high" />
      </picture>
      <div class="absolute inset-0 bg-gradient-to-t from-cobalt-900 via-cobalt-900/85 to-cobalt-900/50"></div>
      <div class="absolute inset-0 bg-gradient-to-r from-cobalt-900/95 via-cobalt-900/65 to-cobalt-900/30"></div>
    </div>

    <div class="container-rp relative pt-24 pb-20 sm:pt-32 sm:pb-28 min-h-[72vh] flex flex-col justify-end">
      <p class="eyebrow text-amber-300 inline-flex items-center gap-2" data-reveal>
        <span class="inline-block w-1.5 h-1.5 rounded-full bg-amber-400 animate-pulse"></span>
        {t(locale, 'nad.hero.eyebrow')} · Premium
      </p>

      <h1
        class="mt-6 text-[42px] sm:text-[64px] lg:text-[88px] font-display font-semibold leading-[0.98] tracking-tight text-balance max-w-4xl text-white"
        data-reveal
        set:html={t(locale, 'nad.hero.title')}
      />
      <p class="mt-6 max-w-2xl text-[17px] sm:text-[20px] text-white/85 leading-relaxed text-pretty" data-reveal>
        {t(locale, 'nad.hero.subtitle')}
      </p>

      <div class="mt-10 flex flex-col sm:flex-row gap-3" data-reveal>
        <a
          href={wa}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2 h-14 px-8 rounded-full bg-amber-400 text-cobalt-900 text-[15px] font-semibold hover:bg-amber-300 transition-all duration-[var(--duration-micro)] [transition-timing-function:var(--ease-out-quart)] active:scale-[0.98] btn-shimmer"
        >
          {t(locale, 'nad.hero.cta')}
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="5" y1="12" x2="19" y2="12"/>
            <polyline points="12 5 19 12 12 19"/>
          </svg>
        </a>
        <a
          href="#variantes"
          class="inline-flex items-center justify-center gap-2 h-14 px-8 rounded-full bg-transparent text-white border border-white/30 text-[15px] font-semibold hover:bg-white/10 hover:border-white/60 transition-all"
        >
          Comparar variantes
        </a>
      </div>
    </div>
  </section>

  {/* ───────────── 3 VARIANTS comparison ───────────── */}
  <section id="variantes" class="container-rp section-y">
    <div class="mb-12 max-w-3xl">
      <p class="eyebrow" data-reveal>Tres variantes</p>
      <h2 class="mt-3 font-display text-[36px] sm:text-[52px] font-semibold leading-[1.04] tracking-tight text-balance" data-reveal>
        El protocolo que <em>tu cuerpo</em> pide.
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 sm:gap-5">
      {NAD_FAMILY.map((suero, i) => {
        const isFeature = i === NAD_FAMILY.length - 1 // longest = premium
        return (
          <div
            data-reveal
            style={`transition-delay: ${i * 80}ms`}
            class={`relative p-7 sm:p-8 rounded-3xl ring-1 transition-all duration-[var(--duration-reveal)] [transition-timing-function:var(--ease-out-quart)] hover:-translate-y-1 ${
              isFeature
                ? 'bg-gradient-to-br from-cobalt-900 to-cobalt-800 text-white ring-amber-400/40 hover:ring-amber-400/70 hover:shadow-[0_30px_60px_-20px_rgba(31,45,90,0.5)]'
                : 'bg-white text-ink-900 ring-cobalt-100 hover:ring-cobalt-300 hover:shadow-[0_30px_60px_-30px_rgba(31,45,90,0.25)]'
            }`}
          >
            {isFeature && (
              <span class="premium-pill absolute -top-3 left-7">Más completo</span>
            )}
            <p class={`text-[11px] uppercase tracking-[0.18em] font-semibold ${isFeature ? 'text-amber-300' : 'text-cobalt-700'}`}>
              Variante 0{i + 1}
            </p>
            <h3 class={`mt-3 font-display text-[28px] sm:text-[32px] font-semibold leading-tight ${isFeature ? 'text-white' : ''}`}>
              {suero.name}
            </h3>
            <p class={`mt-3 text-[14px] leading-relaxed ${isFeature ? 'text-white/85' : 'text-ink-700'}`}>
              {locale === 'en' ? (suero.pitch.en ?? suero.pitch.es) : suero.pitch.es}
            </p>

            <dl class={`mt-6 space-y-3 text-[14px] ${isFeature ? 'text-white/85' : 'text-ink-700'}`}>
              <div class="flex justify-between gap-3">
                <dt class="opacity-70">{locale === 'en' ? 'Duration' : 'Duración'}</dt>
                <dd class="font-semibold tabular-nums">{suero.durationMin} min</dd>
              </div>
              <div class="flex justify-between gap-3">
                <dt class="opacity-70">{locale === 'en' ? 'Price' : 'Precio'}</dt>
                <dd class="font-display text-[22px] font-semibold tabular-nums">{formatMxn(suero.priceMxn)}</dd>
              </div>
              <div class={`pt-3 border-t ${isFeature ? 'border-white/15' : 'border-cobalt-100'}`}>
                <dt class="text-[11px] uppercase tracking-widest opacity-70 mb-1.5">Incluye</dt>
                <dd>{suero.ingredients}</dd>
              </div>
            </dl>

            <a
              href={whatsappLink('nad', { variant: suero.name })}
              target="_blank"
              rel="noopener noreferrer"
              class={`mt-7 inline-flex items-center justify-center gap-2 w-full h-12 rounded-full text-[14px] font-semibold transition-all ${
                isFeature
                  ? 'bg-amber-400 text-cobalt-900 hover:bg-amber-300 btn-shimmer'
                  : 'bg-cobalt-700 text-white hover:bg-cobalt-800'
              }`}
            >
              {locale === 'en' ? 'Book this NAD+' : 'Reservar este NAD+'}
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="5" y1="12" x2="19" y2="12"/>
                <polyline points="12 5 19 12 12 19"/>
              </svg>
            </a>
          </div>
        )
      })}
    </div>
  </section>

  {/* ───────────── WHO FOR ───────────── */}
  <section class="container-rp section-y bg-ivory-50">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10">
      <div class="lg:col-span-5 lg:sticky lg:top-28 self-start">
        <p class="eyebrow" data-reveal>{locale === 'en' ? 'Who is it for' : 'Para quién'}</p>
        <h2 class="mt-3 font-display text-[36px] sm:text-[48px] font-semibold leading-[1.04] tracking-tight text-balance" data-reveal>
          {t(locale, 'nad.whoFor.title')}
        </h2>
      </div>
      <ul class="lg:col-span-7 space-y-3">
        {whoFor.map((item, i) => (
          <li
            data-reveal
            style={`transition-delay: ${i * 60}ms`}
            class="flex items-start gap-4 p-5 rounded-2xl bg-white border border-cobalt-100"
          >
            <span class="shrink-0 inline-flex items-center justify-center w-8 h-8 rounded-full bg-amber-300/40 text-cobalt-900 font-display font-semibold tabular-nums text-[14px]">
              {String(i + 1).padStart(2, '0')}
            </span>
            <p class="text-[15px] text-ink-800 leading-relaxed">{item}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  {/* ───────────── FAQ ───────────── */}
  <section class="container-rp section-y">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
      <div class="lg:col-span-4 lg:sticky lg:top-28 self-start">
        <p class="eyebrow" data-reveal>Preguntas</p>
        <h2 class="mt-3 font-display text-[32px] sm:text-[44px] font-semibold leading-[1.04] tracking-tight text-balance" data-reveal>
          {t(locale, 'nad.faq.title')}
        </h2>
      </div>
      <div class="lg:col-span-8">
        {faq.map((item, i) => (
          <details
            data-reveal
            style={`transition-delay: ${i * 50}ms`}
            class="group border-t border-cobalt-100 py-5 [&_summary::-webkit-details-marker]:hidden"
          >
            <summary class="flex items-center justify-between gap-4 cursor-pointer list-none">
              <h3 class="font-display text-[19px] sm:text-[22px] font-semibold leading-snug text-ink-900 group-hover:text-cobalt-800 transition-colors">{item.q}</h3>
              <span class="shrink-0 inline-flex items-center justify-center w-9 h-9 rounded-full bg-cobalt-50 text-cobalt-700 transition-transform duration-[var(--duration-micro)] group-open:rotate-45">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
                  <line x1="12" y1="5" x2="12" y2="19"/>
                  <line x1="5" y1="12" x2="19" y2="12"/>
                </svg>
              </span>
            </summary>
            <p class="mt-4 text-[15px] text-ink-700 leading-relaxed text-pretty">{item.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  {/* ───────────── FINAL CTA ───────────── */}
  <section data-nav-theme="dark" class="relative isolate overflow-hidden bg-cobalt-900 section-y">
    <div aria-hidden class="absolute -top-32 -right-32 size-[600px] rounded-full bg-amber-400/20 blur-[140px]"></div>
    <div aria-hidden class="absolute -bottom-40 -left-40 size-[540px] rounded-full bg-cobalt-500/30 blur-[140px]"></div>
    <div class="container-rp text-center relative">
      <h2 class="text-[36px] sm:text-[56px] lg:text-[68px] font-display font-semibold leading-[1.04] tracking-tight text-balance max-w-3xl mx-auto text-white" data-reveal>
        Tu primera sesión de <em class="text-amber-300">NAD+</em> empieza aquí.
      </h2>
      <div class="mt-10 flex flex-col sm:flex-row gap-3 justify-center" data-reveal>
        <a
          href={wa}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2 h-14 px-8 rounded-full bg-amber-400 text-cobalt-900 text-[16px] font-semibold hover:bg-amber-300 transition-all btn-shimmer"
        >
          {t(locale, 'nad.hero.cta')}
        </a>
        <a
          href={telLink}
          class="inline-flex items-center justify-center gap-2 h-14 px-8 rounded-full bg-transparent text-white border border-white/30 text-[16px] font-semibold hover:bg-white/10 hover:border-white/60 transition-all"
        >
          {t(locale, 'site.callCta')}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
