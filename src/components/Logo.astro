---
/**
 * Recovery Point — official brand logo.
 *
 * SOURCE: /public/img/logo.svg copied from `_layout-pilots/logo.svg` (official
 * brand asset signed off 2026-05-01). Renders the full lockup (R+ symbol +
 * "recovery point" wordmark) at 1080×1080 viewBox, scaled by the `height`
 * prop. Inline <img> so it caches with the page.
 *
 * The official wordmark is part of the SVG — DO NOT add a separate text
 * span next to it (Mario already flagged that as wrong-logo behavior).
 *
 * For dark backgrounds, set `inverted` true and we'll apply a CSS filter
 * to invert the periwinkle fills to white. Cleanest approach without
 * generating two SVG variants.
 */
interface Props {
  /** Height in px; logo aspect is roughly 1:1 (1080×1080 incl wordmark) */
  height?: number
  className?: string
  /** When true, inverts to white for dark hero backgrounds */
  inverted?: boolean
}

const { height = 56, className = '', inverted = false } = Astro.props as Props
const w = height // 1:1 viewbox
---

<a
  href="/"
  aria-label="Recovery Point — inicio"
  class={`group inline-flex items-center ${className}`}
>
  <img
    src="/img/logo.svg"
    alt="Recovery Point"
    width={w}
    height={height}
    style={`height: ${height}px; width: auto;` + (inverted ? ' filter: brightness(0) invert(1);' : '')}
    class="select-none transition-opacity duration-[var(--duration-micro)] group-hover:opacity-80"
    decoding="async"
  />
</a>
