---
/**
 * Hero background — abstract cobalt + mint glow with floating orbs.
 *
 * Pure SVG + CSS, zero JS. Animation respects prefers-reduced-motion via the
 * media query in global.css. Used only on /index and /nad hero sections.
 *
 * Why this and not a stock image: full visual control of brand color, sharp at
 * any resolution, ~3KB total (vs 200KB for a hero JPG). Per the references
 * dossier §9 anti-patterns: "no stock photos of women in robes."
 */
---

<div class="absolute inset-0 -z-10 overflow-hidden pointer-events-none">
  {/* Base gradient */}
  <div class="absolute inset-0 bg-gradient-to-br from-ivory-50 via-cobalt-50/60 to-mint-50/40"></div>

  {/* Big cobalt orb top-right */}
  <div
    class="absolute -top-32 -right-24 w-[640px] h-[640px] rounded-full opacity-30 blur-3xl"
    style="background: radial-gradient(circle at center, var(--color-cobalt-400) 0%, transparent 70%); animation: float-slow 18s ease-in-out infinite alternate;"
  ></div>

  {/* Mint orb bottom-left */}
  <div
    class="absolute -bottom-40 -left-20 w-[520px] h-[520px] rounded-full opacity-25 blur-3xl"
    style="background: radial-gradient(circle at center, var(--color-mint-300) 0%, transparent 70%); animation: float-slow 22s ease-in-out infinite alternate-reverse;"
  ></div>

  {/* Amber accent top-left */}
  <div
    class="absolute top-1/3 left-1/4 w-[280px] h-[280px] rounded-full opacity-15 blur-2xl"
    style="background: radial-gradient(circle at center, var(--color-amber-400) 0%, transparent 70%); animation: float-slow 26s ease-in-out infinite;"
  ></div>

  {/* Subtle grid lines */}
  <svg
    class="absolute inset-0 w-full h-full opacity-[0.04]"
    aria-hidden="true"
  >
    <defs>
      <pattern id="hero-grid" width="64" height="64" patternUnits="userSpaceOnUse">
        <path d="M 64 0 L 0 0 0 64" fill="none" stroke="var(--color-cobalt-800)" stroke-width="1"/>
      </pattern>
    </defs>
    <rect width="100%" height="100%" fill="url(#hero-grid)"/>
  </svg>

  <style>
    @keyframes float-slow {
      0% { transform: translate3d(0, 0, 0) scale(1); }
      50% { transform: translate3d(12px, -18px, 0) scale(1.04); }
      100% { transform: translate3d(-8px, 14px, 0) scale(0.98); }
    }
    @media (prefers-reduced-motion: reduce) {
      div[style*="animation"] { animation: none !important; }
    }
  </style>
</div>
