---
/**
 * ServiceDetailLayout — shared template for /servicios/{slug} sub-pages.
 *
 * Consumes content from src/lib/service-detail-content.ts so the 8 sub-pages
 * stay one file each (.astro shim that imports + passes content).
 */
import BaseLayout from '@/layouts/BaseLayout.astro'
import HeroBackground from '@/components/HeroBackground.astro'
import { t, getLocaleFromPath } from '@/i18n/messages'
import { telLink, whatsappLink } from '@/lib/contact'
import { type ServiceDetailContent, getServiceDetail } from '@/lib/service-detail-content'
import { SERVICES } from '@/lib/services-catalog'
import { buildServiceSchema, buildBreadcrumbSchema, buildFaqSchema } from '@/lib/jsonld'

interface Props { content: ServiceDetailContent }
const { content: contentProp } = Astro.props as Props
// Locale from URL (/en/servicios/... → 'en').
const locale = getLocaleFromPath(Astro.url.pathname)
// Pages still pass the ES content (legacy SERVICE_DETAILS default), but if we
// are rendering under /en/* we swap to the EN content bank for the same slug.
// This keeps the .astro shims one-liner (`const content = SERVICE_DETAILS[slug]`)
// while delivering correct locale content here.
const content: ServiceDetailContent = locale === 'en'
  ? (getServiceDetail(contentProp.slug, 'en') ?? contentProp)
  : contentProp
const wa = whatsappLink(content.intent)

// Build per-service Schema.org JSON-LD blocks (Service + Breadcrumb + FAQ).
// Matched by slug; if no match, fall back to no extra blocks.
const slug = Astro.url.pathname.split('/').filter(Boolean).pop() || ''
const service = SERVICES.find((s) => s.slug === slug)
const pageUrl = new URL(Astro.url.pathname, Astro.site ?? 'https://rpweb.25ocho.agency').toString()
const extraJsonLd: Array<Record<string, unknown>> = []
if (service) {
  extraJsonLd.push(buildServiceSchema({
    service,
    serviceName: content.hero.eyebrow,
    description: content.hero.subtitle,
    locale,
    pageUrl,
  }))
  extraJsonLd.push(buildBreadcrumbSchema([
    { name: locale === 'en' ? 'Home' : 'Inicio',     url: new URL(locale === 'en' ? '/en/' : '/', Astro.site ?? 'https://rpweb.25ocho.agency').toString() },
    { name: locale === 'en' ? 'Services' : 'Servicios', url: new URL(locale === 'en' ? '/en/servicios/' : '/servicios/', Astro.site ?? 'https://rpweb.25ocho.agency').toString() },
    { name: content.hero.eyebrow, url: pageUrl },
  ]))
}
// FAQ block — if the page ships FAQ items, emit FAQPage schema for rich result.
if (content.faq?.items && content.faq.items.length > 0) {
  extraJsonLd.push(buildFaqSchema(content.faq.items.map((f) => ({ q: f.q, a: f.a }))))
}
---

<BaseLayout
  title={content.hero.eyebrow}
  description={content.hero.subtitle}
  extraJsonLd={extraJsonLd}
>
  {/* ─────────────────────────────── HERO ─────────────────────────────── */}
  <section class="relative isolate overflow-hidden">
    <HeroBackground />
    <div class="container-rp pt-12 pb-12 sm:pt-20 sm:pb-16">
      <p class="eyebrow" data-reveal>{content.hero.eyebrow}</p>
      <h1
        class="mt-4 text-[42px] sm:text-[60px] lg:text-[76px] font-display font-semibold leading-[1.04] tracking-tight text-balance max-w-4xl"
        data-reveal
        set:html={content.hero.title}
      />
      <p
        class="mt-6 max-w-2xl text-[17px] sm:text-[19px] text-ink-700 leading-relaxed text-pretty"
        data-reveal
      >
        {content.hero.subtitle}
      </p>

      {/* Quick facts strip */}
      {content.hero.quickFacts.length > 0 && (
        <ul class="mt-8 flex flex-wrap items-center gap-2" data-reveal>
          {content.hero.quickFacts.map((fact: string) => (
            <li class="inline-flex items-center gap-1.5 px-3 h-9 rounded-full bg-white text-cobalt-800 border border-cobalt-100 text-[13px] font-semibold tracking-tight">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="text-cobalt-600">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              {fact}
            </li>
          ))}
        </ul>
      )}

      <div class="mt-10 flex flex-col sm:flex-row gap-3" data-reveal>
        <a
          href={wa}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2 h-14 px-7 rounded-full bg-cobalt-700 text-white text-[16px] font-semibold hover:bg-cobalt-800 hover:shadow-lg hover:shadow-cobalt-800/25 transition-all duration-[var(--duration-micro)] [transition-timing-function:var(--ease-out-quart)] active:scale-[0.98]"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M.057 24l1.687-6.163a11.867 11.867 0 01-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.817 11.817 0 018.413 3.488 11.824 11.824 0 013.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 01-5.688-1.448L.057 24z"/></svg>
          {content.cta.primary}
        </a>
        <a
          href="/servicios"
          class="inline-flex items-center justify-center gap-2 h-14 px-7 rounded-full bg-white text-cobalt-800 border border-cobalt-200 text-[16px] font-semibold hover:border-cobalt-400 hover:bg-cobalt-50 transition-all duration-[var(--duration-micro)] [transition-timing-function:var(--ease-out-quart)] active:scale-[0.98]"
        >
          Ver todos los servicios
        </a>
      </div>
    </div>
  </section>

  {/* ─────────────────────────────── BENEFITS ─────────────────────────────── */}
  <section class="container-rp section-y">
    <div class="mb-10 max-w-3xl">
      <p class="eyebrow" data-reveal>{content.benefits.eyebrow}</p>
      <h2 class="mt-3 text-[32px] sm:text-[40px] font-display font-semibold leading-tight text-balance" data-reveal>
        {content.benefits.title}
      </h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {content.benefits.items.map((item, i) => (
        <div
          data-reveal
          style={`transition-delay: ${i * 70}ms`}
          class="p-6 sm:p-7 rounded-2xl bg-white border border-cobalt-100/60 hover:border-cobalt-300 hover:-translate-y-1 transition-all duration-[var(--duration-reveal)] [transition-timing-function:var(--ease-out-quart)]"
        >
          <h3 class="font-display text-[22px] font-semibold leading-tight text-ink-900">{item.title}</h3>
          <p class="mt-2 text-[15px] text-ink-700 leading-relaxed text-pretty">{item.description}</p>
        </div>
      ))}
    </div>
  </section>

  {/* ─────────────────────────────── HOW IT WORKS ─────────────────────────────── */}
  <section class="container-rp section-y bg-ivory-50">
    <div class="mb-10 max-w-3xl">
      <p class="eyebrow" data-reveal>{content.howItWorks.eyebrow}</p>
      <h2 class="mt-3 text-[32px] sm:text-[40px] font-display font-semibold leading-tight text-balance" data-reveal>
        {content.howItWorks.title}
      </h2>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {content.howItWorks.steps.map((step, i) => (
        <div
          data-reveal
          style={`transition-delay: ${i * 80}ms`}
          class="relative p-6 rounded-2xl bg-white border border-cobalt-100/60 hover:border-cobalt-300 transition-all duration-[var(--duration-reveal)] [transition-timing-function:var(--ease-out-quart)]"
        >
          <span class="absolute -top-3 -left-1 font-display text-[64px] font-semibold leading-none text-cobalt-100">
            {String(i + 1).padStart(2, '0')}
          </span>
          <div class="relative pt-8">
            <h3 class="font-display text-[20px] font-semibold leading-tight">{step.title}</h3>
            <p class="mt-2 text-[14px] text-ink-700 leading-relaxed">{step.description}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  {/* ─────────────────────────────── WHO FOR (optional) ─────────────────────────────── */}
  {content.whoFor && (
    <section class="container-rp section-y">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10">
        <div class="lg:col-span-5">
          <p class="eyebrow" data-reveal>{content.whoFor.eyebrow}</p>
          <h2 class="mt-3 text-[32px] sm:text-[40px] font-display font-semibold leading-tight text-balance" data-reveal>
            {content.whoFor.title}
          </h2>
        </div>
        <ul class="lg:col-span-7 space-y-3">
          {content.whoFor.items.map((item, i) => (
            <li
              data-reveal
              style={`transition-delay: ${i * 60}ms`}
              class="flex items-start gap-3 p-4 rounded-xl bg-white border border-cobalt-100/60"
            >
              <span class="shrink-0 inline-flex items-center justify-center w-6 h-6 rounded-full bg-cobalt-100 text-cobalt-700 mt-0.5">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
              </span>
              <p class="text-[15px] text-ink-700 leading-relaxed">{item}</p>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  {/* ─────────────────────────────── FAQ ─────────────────────────────── */}
  <section class="container-rp section-y">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
      <div class="lg:col-span-4 lg:sticky lg:top-28 self-start">
        <p class="eyebrow" data-reveal>{content.faq.eyebrow}</p>
        <h2 class="mt-3 text-[32px] sm:text-[40px] font-display font-semibold leading-tight text-balance" data-reveal>
          {content.faq.title}
        </h2>
      </div>
      <div class="lg:col-span-8">
        {content.faq.items.map((item, i) => (
          <details
            data-reveal
            style={`transition-delay: ${i * 60}ms`}
            class="group border-t border-cobalt-100 py-5 [&_summary::-webkit-details-marker]:hidden"
          >
            <summary class="flex items-center justify-between gap-4 cursor-pointer list-none">
              <h3 class="font-display text-[18px] sm:text-[20px] font-semibold leading-snug text-ink-900 group-hover:text-cobalt-800 transition-colors">{item.q}</h3>
              <span class="shrink-0 inline-flex items-center justify-center w-9 h-9 rounded-full bg-cobalt-50 text-cobalt-700 transition-transform duration-[var(--duration-micro)] group-open:rotate-45">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
                  <line x1="12" y1="5" x2="12" y2="19"/>
                  <line x1="5" y1="12" x2="19" y2="12"/>
                </svg>
              </span>
            </summary>
            <p class="mt-4 text-[15px] text-ink-700 leading-relaxed text-pretty">{item.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  {/* ─────────────────────────────── FINAL CTA ─────────────────────────────── */}
  <section class="container-rp section-y">
    <div class="rounded-3xl p-8 sm:p-12 bg-gradient-to-br from-cobalt-50 via-ivory-50 to-cobalt-50/40 text-center">
      <h2 class="text-[32px] sm:text-[44px] font-display font-semibold leading-tight text-balance max-w-2xl mx-auto" data-reveal>
        {content.cta.title}
      </h2>
      <div class="mt-8 flex flex-col sm:flex-row gap-3 justify-center" data-reveal>
        <a
          href={wa}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2 h-14 px-8 rounded-full bg-cobalt-700 text-white text-[16px] font-semibold hover:bg-cobalt-800 hover:shadow-lg hover:shadow-cobalt-800/30 transition-all duration-[var(--duration-micro)] [transition-timing-function:var(--ease-out-quart)]"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M.057 24l1.687-6.163a11.867 11.867 0 01-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.817 11.817 0 018.413 3.488 11.824 11.824 0 013.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 01-5.688-1.448L.057 24z"/></svg>
          {content.cta.primary}
        </a>
        <a
          href={telLink}
          class="inline-flex items-center justify-center gap-2 h-14 px-8 rounded-full bg-white text-cobalt-800 border border-cobalt-200 text-[16px] font-semibold hover:border-cobalt-400 hover:bg-cobalt-50 transition-all duration-[var(--duration-micro)] [transition-timing-function:var(--ease-out-quart)]"
        >
          {t(locale, 'site.callCta')}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
