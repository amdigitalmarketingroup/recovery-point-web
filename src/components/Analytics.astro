---
/**
 * Analytics — GA4 + Meta Pixel injection.
 *
 * Both providers are gated on PUBLIC_* env vars; if unset, the script
 * is not emitted (zero overhead in preview/staging). Set in Hostinger
 * panel or .env.production before the live cutover:
 *   PUBLIC_GA4_ID=G-XXXXXXXXXX
 *   PUBLIC_META_PIXEL_ID=123456789012345
 *
 * Pageviews fire automatically; custom events (form_submit, whatsapp_click,
 * service_view) emit via `window.dataLayer.push({ event: 'X', ... })` /
 * `window.fbq('track', 'X', ...)` from inline scripts on each page.
 *
 * Consent: this is a clinic in Mexico (no GDPR mandate); we follow
 * Meta-style minimal consent — banner deferred to fase post-launch.
 */
const GA4_ID = import.meta.env.PUBLIC_GA4_ID
const META_PIXEL_ID = import.meta.env.PUBLIC_META_PIXEL_ID
---

{GA4_ID && (
  <>
    <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${GA4_ID}`}></script>
    <script is:inline set:html={`
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      window.gtag = gtag;
      gtag('js', new Date());
      gtag('config', '${GA4_ID}', { anonymize_ip: true });
    `}></script>
  </>
)}

{META_PIXEL_ID && (
  <>
    <script is:inline set:html={`
      !function(f,b,e,v,n,t,s)
      {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
      n.callMethod.apply(n,arguments):n.queue.push(arguments)};
      if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
      n.queue=[];t=b.createElement(e);t.async=!0;
      t.src=v;s=b.getElementsByTagName(e)[0];
      s.parentNode.insertBefore(t,s)}(window, document,'script',
      'https://connect.facebook.net/en_US/fbevents.js');
      fbq('init', '${META_PIXEL_ID}');
      fbq('track', 'PageView');
    `}></script>
    <noscript>
      <img height="1" width="1" style="display:none"
           src={`https://www.facebook.com/tr?id=${META_PIXEL_ID}&ev=PageView&noscript=1`} />
    </noscript>
  </>
)}
